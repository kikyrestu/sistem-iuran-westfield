# Database
DATABASE_URL="postgresql://neondb_owner:xxxxx@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="ganti-dengan-random-secret-yang-panjang"

# Midtrans Payment Gateway
# Daftar di https://midtrans.com
# Dashboard sandbox: https://dashboard.sandbox.midtrans.com
MIDTRANS_SERVER_KEY="SB-Mid-server-xxx"
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxx"
MIDTRANS_IS_PRODUCTION="false"

# Untuk production, ganti key dari dashboard production Midtrans
# dan set MIDTRANS_IS_PRODUCTION="true"

# Notification URL (set juga di dashboard Midtrans > Settings > Configuration)
# https://domain-kamu.com/api/payment/callback

# Server Info
SERVER_NAME="Westfield Roleplay"
